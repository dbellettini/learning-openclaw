# Copy this file to .env and fill in the values you need.
# .env is git-ignored — never commit real secrets.

# -----------------------------------------------------------------------------
# Gateway
# -----------------------------------------------------------------------------
# Leave blank to auto-generate on first start.
# To generate manually: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# Bind to lan (default) so the web UI is reachable from the host browser.
OPENCLAW_GATEWAY_BIND=lan

# Ports (defaults shown)
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_BRIDGE_PORT=18790

# Timezone inside the container
OPENCLAW_TZ=UTC

# Pre-built image (override to pin a specific version, e.g. 2026.2.26)
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# -----------------------------------------------------------------------------
# LLM provider — set at least one
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# -----------------------------------------------------------------------------
# Channels — set only what you enable
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
